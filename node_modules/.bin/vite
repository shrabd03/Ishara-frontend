#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/vite@7.3.2_@types+node@25.6_a5a42c4522dcf974d4bb8a12fbdf81cb/node_modules/vite/node_modules:/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/vite@7.3.2_@types+node@25.6_a5a42c4522dcf974d4bb8a12fbdf81cb/node_modules:/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/vite@7.3.2_@types+node@25.6_a5a42c4522dcf974d4bb8a12fbdf81cb/node_modules/vite/node_modules:/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/vite@7.3.2_@types+node@25.6_a5a42c4522dcf974d4bb8a12fbdf81cb/node_modules:/mnt/c/projects/Ishara-Jordanian-Website/Ishara-Jordanian-Website/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vite/bin/vite.js" "$@"
else
  exec node  "$basedir/../vite/bin/vite.js" "$@"
fi
